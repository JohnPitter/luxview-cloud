# =============================================================================
# LuxView Cloud Platform — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# =============================================================================

# -- Domain -------------------------------------------------------------------
DOMAIN=luxview.cloud

# -- Engine -------------------------------------------------------------------
ENGINE_PORT=8080
LOG_LEVEL=info                          # debug, info, warn, error
BUILD_CONCURRENCY=3                     # Max concurrent builds

# -- Platform Database (pg-platform) -----------------------------------------
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD   # PostgreSQL password for platform DB

# -- Security -----------------------------------------------------------------
ENCRYPTION_KEY=CHANGE_ME_32_CHARS_MIN!! # AES-256-GCM key (min 32 characters)
JWT_SECRET=CHANGE_ME_RANDOM_SECRET      # JWT signing secret

# -- GitHub OAuth App --------------------------------------------------------
# Create at: https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# -- Shared PostgreSQL (pg-shared) -------------------------------------------
SHARED_PG_PASSWORD=CHANGE_ME_PG_SHARED  # Password for luxview_admin on pg-shared

# -- Shared Redis (redis-shared) ---------------------------------------------
SHARED_REDIS_PASSWORD=CHANGE_ME_REDIS   # Redis AUTH password

# -- Shared MongoDB (mongo-shared) -------------------------------------------
SHARED_MONGO_PASSWORD=CHANGE_ME_MONGO   # MongoDB root password

# -- Shared RabbitMQ (rabbitmq-shared) ---------------------------------------
SHARED_RABBITMQ_USER=luxview_admin
SHARED_RABBITMQ_PASSWORD=CHANGE_ME_RABBIT  # RabbitMQ admin password

# -- Let's Encrypt (production only) -----------------------------------------
ACME_EMAIL=admin@luxview.cloud          # Email for SSL certificate notifications
