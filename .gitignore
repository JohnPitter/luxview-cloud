# =============================================================================
# LuxView Cloud Platform — .gitignore
# =============================================================================

# -- Environment & Secrets ----------------------------------------------------
.env
.env.local
.env.*.local

# -- Node.js ------------------------------------------------------------------
node_modules/
dist/
build/
.vite/
*.tsbuildinfo

# -- Go -----------------------------------------------------------------------
luxview-engine/tmp/
luxview-engine/engine

# -- Docker volumes (local dev) -----------------------------------------------
volumes/
data/

# -- Traefik ------------------------------------------------------------------
traefik/acme.json
traefik/certs/

# -- Build artifacts ----------------------------------------------------------
*.exe
*.dll
*.so
*.dylib

# -- Logs ---------------------------------------------------------------------
*.log
logs/

# -- OS files -----------------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini

# -- IDE ----------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# -- Temporary -----------------------------------------------------------------
tmp/
temp/
*.tmp

# -- Backups (local) ----------------------------------------------------------
backups/
*.sql.gz
*.archive.gz
*.rdb
