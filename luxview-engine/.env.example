# Server
PORT=8080
BASE_URL=http://localhost:8080
DOMAIN=luxview.cloud
LOG_LEVEL=debug
LOG_FORMAT=console

# Database (platform)
DATABASE_URL=postgres://luxview:luxview@localhost:5432/luxview_platform?sslmode=disable

# Security
ENCRYPTION_KEY=your-32-byte-encryption-key-here!
JWT_SECRET=your-jwt-secret-here

# GitHub OAuth
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Shared PostgreSQL
SHARED_PG_HOST=pg-shared
SHARED_PG_PORT=5432
SHARED_PG_USER=luxview_admin
SHARED_PG_PASSWORD=your-shared-pg-password

# Shared Redis
SHARED_REDIS_HOST=redis-shared
SHARED_REDIS_PORT=6379
SHARED_REDIS_PASSWORD=your-shared-redis-password

# Shared MongoDB
SHARED_MONGO_HOST=mongo-shared
SHARED_MONGO_PORT=27017
SHARED_MONGO_USER=luxview_admin
SHARED_MONGO_PASSWORD=your-shared-mongo-password

# Shared RabbitMQ
SHARED_RABBIT_HOST=rabbitmq-shared
SHARED_RABBIT_PORT=5672
SHARED_RABBIT_USER=luxview_admin
SHARED_RABBIT_PASSWORD=your-shared-rabbit-password

# Build
BUILD_CONCURRENCY=3
BUILD_TIMEOUT=300
PORT_RANGE_START=10000
PORT_RANGE_END=65000

# Workers
METRICS_INTERVAL=30
HEALTHCHECK_INTERVAL=15
CLEANUP_INTERVAL=3600
ALERT_INTERVAL=60

# Internal
INTERNAL_TOKEN=
